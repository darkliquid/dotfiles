{
  "go.lintTool": "golangci-lint-v2",
  "go.lintFlags": [
    "--path-mode=abs",
    "--fast-only"
  ],
  "go.formatTool": "custom",
  "go.alternateTools": {
    "customFormatter": "golangci-lint-v2"
  },
  "go.formatFlags": [
    "fmt",
    "--stdin"
  ],
  "redhat.telemetry.enabled": false,
  "vsix.sources": {
    "opn": {
      "type": "marketplace",
      "serviceUrl": "https://open-vsx.org/vscode/gallery"
    }
  },
  "vsix.extensions": [
    "opn:alefragnani.bookmarks",
    "opn:bungcip.better-toml",
    "opn:cardinal90.multi-cursor-case-preserve",
    "opn:davidanson.vscode-markdownlint",
    "opn:donjayamanne.githistory",
    "opn:esbenp.prettier-vscode",
    "opn:fabiospampinato.vscode-highlight",
    "opn:golang.go",
    "opn:gruntfuggly.todo-tree",
    "opn:hverlin.mise-vscode",
    "opn:johnpapa.vscode-peacock",
    "opn:kdl-org.kdl",
    "opn:mhutchie.git-graph",
    "opn:oderwat.indent-rainbow",
    "opn:redhat.vscode-yaml",
    "opn:yzhang.markdown-all-in-one",
    "opn:zokugun.cron-tasks",
    "opn:zokugun.vsix-manager"
  ],
  "highlight.regexes": {
    "((?:<!-- *)?(?:#|// @|//|./\\*+|<!--|--|\\* @|{!|{{!--|{{!) *TODO(?:[\\t\\f\\v ]*\\([^\\r\\n)]+\\))?:?)((?!\\w)(?: *-->| *\\*/| *!}| *--}}| *}}|(?= *(?:[^\\r\\n:]//|/\\*+|<!--|@|--|{!|{{!--|{{!))|(?: +[^\\r\\n@]*?)(?= *(?:[^\\r\\n:]//|/\\*+|<!--|@|--(?!>)|{!|{{!--|{{!))|(?: +[^\\r\\n@]+)?))": {
      "filterFileRegex": ".*(?<!CHANGELOG.md)$",
      "decorations": [
        {
          "overviewRulerColor": "#ffcc00",
          "backgroundColor": "#ffcc00",
          "color": "#1f1f1f",
          "fontWeight": "bold"
        },
        {
          "backgroundColor": "#ffcc00",
          "color": "#1f1f1f"
        }
      ]
    },
    "((?:<!-- *)?(?:#|// @|//|./\\*+|<!--|--|\\* @|{!|{{!--|{{!) *(?:FIXME|FIX|BUG|UGLY|DEBUG|HACK)(?:[\\t\\f\\v ]*\\([^\\r\\n)]+\\))?:?)((?!\\w)(?: *-->| *\\*/| *!}| *--}}| *}}|(?= *(?:[^\\r\\n:]//|/\\*+|<!--|@|--|{!|{{!--|{{!))|(?: +[^\\r\\n@]*?)(?= *(?:[^\\r\\n:]//|/\\*+|<!--|@|--(?!>)|{!|{{!--|{{!))|(?: +[^\\r\\n@]+)?))": {
      "filterFileRegex": ".*(?<!CHANGELOG.md)$",
      "decorations": [
        {
          "overviewRulerColor": "#cc0000",
          "backgroundColor": "#cc0000",
          "color": "#1f1f1f",
          "fontWeight": "bold"
        },
        {
          "backgroundColor": "#cc0000",
          "color": "#1f1f1f"
        }
      ]
    }
  },
  "workbench.colorTheme": "Dynamic Base16 DankShell",
  "go.toolsManagement.autoUpdate": true,
  "explorer.confirmDelete": false,
  "claudeCode.preferredLocation": "sidebar",
  "http.systemCertificatesNode": true,
  "mise.configureExtensionsAutomatically": true,
  "gopls": {
    "build.env": {
      "CGO_ENABLED": "0"
    },
    "ui.vulncheck": "Imports",
  },
  "chat.agent.maxRequests": 1000,
  "github.copilot.chat.claudeAgent.allowDangerouslySkipPermissions": true,
  "beads.pathToBd": "",
  "yaml.schemas": {
    "file:///home/darkliquid/.vscode-insiders/extensions/continue.continue-1.2.17-linux-x64/config-yaml-schema.json": [
      ".continue/**/*.yaml"
    ],
    "file:///home/darkliquid/.vscode-insiders/extensions/continue.continue-1.3.33-linux-x64/config-yaml-schema.json": [
      ".continue/**/*.yaml"
    ]
  },
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.qrc": "default",
    "*.qrc": "qt-core.qrcEditor"
  },
  "qt-core.additionalQtPaths": [
    {
      "name": "Qt-5.15.18-linux-g++_from_PATH",
      "path": "/usr/bin/qmake"
    },
    {
      "name": "Qt-5.15.18-linux-g++_from_PATH",
      "path": "/usr/bin/qtpaths"
    }
  ],
  "terminal.integrated.defaultProfile.linux": "bash",
  "geminicodeassist.project": "summer-facet-3ht61",
  "diffEditor.codeLens": true,
  "python.analysis.showOnlyDirectDependenciesInAutoImport": true,
  "chat.autopilot.enabled": true,
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "git.autofetch": true,
"makefile.configureOnOpen": true,
"chat.tools.terminal.autoApprove": {
  "mise": true,
  "tasks/compare_parity_frames.sh": true,
  "awk": true,
  "magick": true,
  "git add": true,
  "git commit": true
},
"chat.viewSessions.orientation": "stacked",
"tailwindCSS.includeLanguages": {
  "templ": "html"
},
"emmet.includeLanguages": {
  "templ": "html"
},
"json.schemaDownload.trustedDomains": {
  "https://developer.microsoft.com/json-schemas/": true,
  "https://json-schema.org/": true,
  "https://json.schemastore.org/": true,
  "https://raw.githubusercontent.com/devcontainers/spec/": true,
  "https://raw.githubusercontent.com/microsoft/vscode/": true,
  "https://schemastore.azurewebsites.net/": true,
  "https://wails.io": true,
  "https://www.schemastore.org/": true
},
}